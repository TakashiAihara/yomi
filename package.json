{
  "name": "yomi",
  "version": "1.0.0",
  "private": true,
  "description": "RSS Reader application with microservice architecture",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "lint": "turbo run lint",
